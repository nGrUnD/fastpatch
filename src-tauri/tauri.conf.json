{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fastpatch",
  "version": "0.2.1",
  "identifier": "com.fastpatch.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "fastpatch",
        "width": 960,
        "height": 680,
        "minWidth": 800,
        "minHeight": 560,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../strategies.json",
      "icons/icon.ico",
      "../resources/zapret-extra/lists/list-apex.txt",
      "../resources/zapret-extra/general (APEX).bat"
    ],
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
